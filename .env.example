NODE_ENV=development
PRODUCT_NAME=SecureStream
POSTGRES_USER=securestream
POSTGRES_PASSWORD=securestream
POSTGRES_DB=securestream
DATABASE_URL=postgresql://securestream:securestream@postgres:5432/securestream
REDIS_URL=redis://redis:6379
JWT_ACCESS_SECRET=replace-with-32-or-more-random-characters
JWT_REFRESH_SECRET=replace-with-an-independent-random-secret
PLAYBACK_SIGNING_SECRET=replace-with-an-independent-random-secret
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
EMAIL_TOKEN_TTL_MINUTES=30
ADMIN_COOKIE_NAME=ss_admin
ADMIN_CSRF_COOKIE_NAME=ss_csrf
PLAYBACK_SESSION_TTL_SECONDS=300
REGISTRATION_ENABLED=true
MAX_CONCURRENT_STREAMS=2
ADMIN_ORIGIN=http://localhost:3000
API_PUBLIC_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=/data/media
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
DRM_PROVIDER=development
WIDEVINE_LICENSE_URL=
WIDEVINE_PROVIDER_API_KEY=
WORKER_CONCURRENCY=1
FFMPEG_THREADS=2
ENABLED_RENDITIONS=360,480,720
MAX_UPLOAD_BYTES=10737418240
TEMP_PROCESSING_DIR=/data/tmp
TEMP_STORAGE_MIN_FREE_BYTES=5368709120
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_FOLDER_ID=
DISCORD_WEBHOOK_URL=
ALERT_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
