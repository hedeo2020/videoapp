generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
  VIEWER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DISABLED
}

enum PublishStatus {
  DRAFT
  PUBLISHED
  UNPUBLISHED
  ARCHIVED
}

enum AssetState {
  UPLOADING
  UPLOADED
  QUEUED
  PROCESSING
  READY
  FAILED
  ARCHIVED
}

enum UploadStatus {
  CREATED
  PARTS_ISSUED
  COMPLETED
  ABORTED
}

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  displayName      String
  passwordHash     String
  role             Role              @default(VIEWER)
  status           UserStatus        @default(ACTIVE)
  emailVerifiedAt  DateTime?
  failedLoginCount Int               @default(0)
  lockedUntil      DateTime?
  accessRestricted Boolean           @default(false)
  defaultCollectionId String?
  deletedAt        DateTime?
  deletedReason    String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  defaultCollection Collection?       @relation("UserDefaultCollection", fields: [defaultCollectionId], references: [id], onDelete: SetNull)
  sessions         RefreshSession[]
  playbackSessions PlaybackSession[]
  progress         WatchProgress[]
  history          WatchHistory[]
  myList           MyListItem[]
  movieAccess      UserMovieAccess[]
  collectionAccess UserCollectionAccess[]
  apiTokens        ApiToken[]
  passwordResets   PasswordResetToken[]
  emailVerifications EmailVerificationToken[]
  supportConversations SupportConversation[] @relation("ConversationUser")
  supportMessages SupportMessage[] @relation("MessageSender")
  notifications    UserNotification[]

  @@index([deletedAt])
}

model ApiToken {
  id          String    @id @default(uuid())
  userId      String
  name        String
  tokenHash   String    @unique
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([revokedAt])
}

model RefreshSession {
  id           String    @id @default(uuid())
  userId       String
  deviceId     String
  tokenHash    String    @unique
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String?
  tokenFamily  String
  userAgent    String?
  ipHash       String?
  lastUsedAt   DateTime  @default(now())
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([tokenFamily])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Movie {
  id                String           @id @default(uuid())
  title             String
  synopsis          String
  slug              String           @unique
  status            PublishStatus    @default(DRAFT)
  featured          Boolean          @default(false)
  posterUrl         String?
  backdropUrl       String?
  trailerUrl        String?
  genres            String[]         @default([])
  tags              String[]         @default([])
  releaseDate       DateTime?
  maturityRating    String?
  availabilityStart DateTime?
  availabilityEnd   DateTime?
  version           Int              @default(1)
  deletedAt         DateTime?
  deletedReason     String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  assets            VideoAsset[]
  collectionItems   CollectionItem[]
  userAccess        UserMovieAccess[]

  @@index([deletedAt])
}

model Series {
  id              String           @id @default(uuid())
  title           String
  synopsis        String
  slug            String           @unique
  status          PublishStatus    @default(DRAFT)
  posterUrl       String?
  backdropUrl     String?
  genres          String[]         @default([])
  tags            String[]         @default([])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  seasons         Season[]
  collectionItems CollectionItem[]
}

model Season {
  id       String    @id @default(uuid())
  seriesId String
  number   Int
  title    String?
  series   Series    @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  episodes Episode[]

  @@unique([seriesId, number])
}

model Episode {
  id       String        @id @default(uuid())
  seasonId String
  number   Int
  title    String
  synopsis String
  status   PublishStatus @default(DRAFT)
  season   Season        @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  assets   VideoAsset[]

  @@unique([seasonId, number])
}

model VideoAsset {
  id                 String             @id @default(uuid())
  movieId            String?
  episodeId          String?
  state              AssetState         @default(UPLOADING)
  durationSeconds    Int?
  sourceStorageKey   String
  manifestStorageKey String?
  drmScheme          String?
  drmKeyId           String?
  licensePolicy      Json?
  failureReason      String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  movie              Movie?             @relation(fields: [movieId], references: [id])
  episode            Episode?           @relation(fields: [episodeId], references: [id])
  renditions         VideoRendition[]
  playbackSessions   PlaybackSession[]
  progress           WatchProgress[]
  history            WatchHistory[]
  uploads            Upload[]

  @@index([state])
}

model VideoRendition {
  id           String     @id @default(uuid())
  videoAssetId String
  height       Int
  bitrateKbps  Int
  codec        String
  storageKey   String
  videoAsset   VideoAsset @relation(fields: [videoAssetId], references: [id], onDelete: Cascade)

  @@unique([videoAssetId, height])
}

model Collection {
  id        String           @id @default(uuid())
  name      String
  slug      String           @unique
  published Boolean          @default(false)
  sortOrder Int              @default(0)
  parentId  String?
  parent    Collection?       @relation("CollectionHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children  Collection[]      @relation("CollectionHierarchy")
  items     CollectionItem[]
  userAccess UserCollectionAccess[]
  defaultForUsers User[]      @relation("UserDefaultCollection")

  @@index([parentId])
}

model UserMovieAccess {
  id        String   @id @default(uuid())
  userId    String
  movieId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@index([movieId])
}

model UserCollectionAccess {
  id           String     @id @default(uuid())
  userId       String
  collectionId String
  createdAt    DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([userId, collectionId])
  @@index([collectionId])
}

model CollectionItem {
  id           String     @id @default(uuid())
  collectionId String
  movieId      String?
  seriesId     String?
  sortOrder    Int        @default(0)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  movie        Movie?     @relation(fields: [movieId], references: [id])
  series       Series?    @relation(fields: [seriesId], references: [id])

  @@unique([collectionId, sortOrder])
}

model PlaybackSession {
  id           String     @id
  userId       String
  videoAssetId String
  deviceId     String
  expiresAt    DateTime
  revokedAt    DateTime?
  riskSignals  String[]
  createdAt    DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id])
  videoAsset   VideoAsset @relation(fields: [videoAssetId], references: [id])

  @@index([userId, expiresAt])
}

model WatchProgress {
  id              String     @id @default(uuid())
  userId          String
  videoAssetId    String
  positionSeconds Int
  completed       Boolean    @default(false)
  version         Int        @default(1)
  updatedAt       DateTime   @updatedAt
  user            User       @relation(fields: [userId], references: [id])
  videoAsset      VideoAsset @relation(fields: [videoAssetId], references: [id])

  @@unique([userId, videoAssetId])
}

model WatchHistory {
  id           String     @id @default(uuid())
  userId       String
  videoAssetId String
  watchedAt    DateTime   @default(now())
  removedAt    DateTime?
  user         User       @relation(fields: [userId], references: [id])
  videoAsset   VideoAsset @relation(fields: [videoAssetId], references: [id])

  @@index([userId, watchedAt])
}

model MyListItem {
  id        String   @id @default(uuid())
  userId    String
  catalogId String
  kind      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, catalogId])
}

model Upload {
  id            String     @id @default(uuid())
  videoAssetId  String
  storageKey    String
  uploadId      String?
  parts         Json?
  bytesExpected BigInt
  bytesReceived BigInt     @default(0)
  status        UploadStatus @default(CREATED)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  videoAsset    VideoAsset @relation(fields: [videoAssetId], references: [id])
}

model AdminAuditLog {
  id          String   @id @default(uuid())
  actorUserId String
  action      String
  targetType  String
  targetId    String?
  requestId   String
  ipHash      String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([actorUserId, createdAt])
}

model PlatformSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model SupportConversation {
  id        String           @id @default(uuid())
  userId    String
  status    String           @default("OPEN")
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation("ConversationUser", fields: [userId], references: [id], onDelete: Cascade)
  messages  SupportMessage[]

  @@unique([userId])
  @@index([updatedAt])
}

model SupportMessage {
  id             String              @id @default(uuid())
  conversationId String
  senderUserId   String
  body           String
  readAt         DateTime?
  createdAt      DateTime            @default(now())
  conversation   SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User                @relation("MessageSender", fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderUserId])
}

model UserNotification {
  id        String    @id @default(uuid())
  userId    String
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([readAt])
}

model SecurityEvent {
  id        String   @id @default(uuid())
  userId    String?
  kind      String
  severity  String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([kind, createdAt])
}
