generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
  VIEWER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DISABLED
}

enum PublishStatus {
  DRAFT
  PUBLISHED
  UNPUBLISHED
  ARCHIVED
}

enum AssetState {
  UPLOADING
  UPLOADED
  QUEUED
  PROCESSING
  READY
  FAILED
  ARCHIVED
}

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  displayName      String
  passwordHash     String
  role             Role              @default(VIEWER)
  status           UserStatus        @default(ACTIVE)
  emailVerifiedAt  DateTime?
  failedLoginCount Int               @default(0)
  lockedUntil      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  sessions         RefreshSession[]
  playbackSessions PlaybackSession[]
  progress         WatchProgress[]
  history          WatchHistory[]
  myList           MyListItem[]
  passwordResets   PasswordResetToken[]
  emailVerifications EmailVerificationToken[]
}

model RefreshSession {
  id           String    @id @default(uuid())
  userId       String
  deviceId     String
  tokenHash    String    @unique
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String?
  tokenFamily  String
  userAgent    String?
  ipHash       String?
  lastUsedAt   DateTime  @default(now())
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([tokenFamily])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Movie {
  id                String           @id @default(uuid())
  title             String
  synopsis          String
  slug              String           @unique
  status            PublishStatus    @default(DRAFT)
  featured          Boolean          @default(false)
  releaseDate       DateTime?
  maturityRating    String?
  availabilityStart DateTime?
  availabilityEnd   DateTime?
  version           Int              @default(1)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  assets            VideoAsset[]
  collectionItems   CollectionItem[]
}

model Series {
  id              String           @id @default(uuid())
  title           String
  synopsis        String
  slug            String           @unique
  status          PublishStatus    @default(DRAFT)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  seasons         Season[]
  collectionItems CollectionItem[]
}

model Season {
  id       String    @id @default(uuid())
  seriesId String
  number   Int
  title    String?
  series   Series    @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  episodes Episode[]

  @@unique([seriesId, number])
}

model Episode {
  id       String        @id @default(uuid())
  seasonId String
  number   Int
  title    String
  synopsis String
  status   PublishStatus @default(DRAFT)
  season   Season        @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  assets   VideoAsset[]

  @@unique([seasonId, number])
}

model VideoAsset {
  id                 String             @id @default(uuid())
  movieId            String?
  episodeId          String?
  state              AssetState         @default(UPLOADING)
  durationSeconds    Int?
  sourceStorageKey   String
  manifestStorageKey String?
  drmScheme          String?
  failureReason      String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  movie              Movie?             @relation(fields: [movieId], references: [id])
  episode            Episode?           @relation(fields: [episodeId], references: [id])
  renditions         VideoRendition[]
  playbackSessions   PlaybackSession[]
  progress           WatchProgress[]
  history            WatchHistory[]
  uploads            Upload[]

  @@index([state])
}

model VideoRendition {
  id           String     @id @default(uuid())
  videoAssetId String
  height       Int
  bitrateKbps  Int
  codec        String
  storageKey   String
  videoAsset   VideoAsset @relation(fields: [videoAssetId], references: [id], onDelete: Cascade)

  @@unique([videoAssetId, height])
}

model Collection {
  id        String           @id @default(uuid())
  name      String
  slug      String           @unique
  published Boolean          @default(false)
  sortOrder Int              @default(0)
  items     CollectionItem[]
}

model CollectionItem {
  id           String     @id @default(uuid())
  collectionId String
  movieId      String?
  seriesId     String?
  sortOrder    Int        @default(0)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  movie        Movie?     @relation(fields: [movieId], references: [id])
  series       Series?    @relation(fields: [seriesId], references: [id])

  @@unique([collectionId, sortOrder])
}

model PlaybackSession {
  id           String     @id
  userId       String
  videoAssetId String
  deviceId     String
  expiresAt    DateTime
  revokedAt    DateTime?
  riskSignals  String[]
  createdAt    DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id])
  videoAsset   VideoAsset @relation(fields: [videoAssetId], references: [id])

  @@index([userId, expiresAt])
}

model WatchProgress {
  id              String     @id @default(uuid())
  userId          String
  videoAssetId    String
  positionSeconds Int
  completed       Boolean    @default(false)
  version         Int        @default(1)
  updatedAt       DateTime   @updatedAt
  user            User       @relation(fields: [userId], references: [id])
  videoAsset      VideoAsset @relation(fields: [videoAssetId], references: [id])

  @@unique([userId, videoAssetId])
}

model WatchHistory {
  id           String     @id @default(uuid())
  userId       String
  videoAssetId String
  watchedAt    DateTime   @default(now())
  removedAt    DateTime?
  user         User       @relation(fields: [userId], references: [id])
  videoAsset   VideoAsset @relation(fields: [videoAssetId], references: [id])

  @@index([userId, watchedAt])
}

model MyListItem {
  id        String   @id @default(uuid())
  userId    String
  catalogId String
  kind      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, catalogId])
}

model Upload {
  id            String     @id @default(uuid())
  videoAssetId  String
  storageKey    String
  uploadId      String?
  bytesExpected BigInt
  bytesReceived BigInt     @default(0)
  status        String     @default("CREATED")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  videoAsset    VideoAsset @relation(fields: [videoAssetId], references: [id])
}

model AdminAuditLog {
  id          String   @id @default(uuid())
  actorUserId String
  action      String
  targetType  String
  targetId    String?
  requestId   String
  ipHash      String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([actorUserId, createdAt])
}

model PlatformSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model SecurityEvent {
  id        String   @id @default(uuid())
  userId    String?
  kind      String
  severity  String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([kind, createdAt])
}
